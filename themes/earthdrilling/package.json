{
  "name": "hny-theme_boilerplate",
  "version": "1.3.2",
  "description": "Webpack-powered WordPress theme boilerplate",
  "homepage": "https://www.honeycombcreative.com",
  "scripts": {
    "postinstall": "yarn production",
    "gulp": "gulp --gulpfile build/gulpfile.babel.js",
    "webpack": "webpack --config build/webpack.config.babel.js",
    "watch": "yarn clean && run-p \"webpack --hide-modules\" \"gulp\"",
    "production": "yarn clean && cross-env NODE_ENV=production BABEL_ENV=production run-p \"webpack --progress\" \"gulp build\"",
    "format": "phpcbf . --standard=WordPress-Core --extensions=php --ignore=node_modules/*,dist/* -p -v && eslint . --fix --ignore-path .gitignore --ext .js",
    "clean": "rimraf dist",
    "precommit": "yarn format && yarn production"
  },
  "author": "Honeycomb Creative",
  "license": "ISC",
  "dependencies": {
    "foundation-sites": "^6.6.1",
    "hc-sticky": "^2.2.3",
    "in-view": "^0.6.1",
    "jquery": "^3.5.1",
    "jquery-clickout": "^0.0.3",
    "motion-ui": "^2.0.3",
    "qs": "^6.9.4",
    "slick-carousel": "^1.8.1",
    "what-input": "^5.2.10"
  },
  "devDependencies": {
    "@babel/core": "^7.10.2",
    "@babel/preset-env": "^7.10.2",
    "@babel/register": "^7.10.1",
    "autoprefixer": "^9.8.0",
    "babel-loader": "^8.1.0",
    "browser-sync": "^2.26.7",
    "cross-env": "^7.0.2",
    "css-declaration-sorter": "5.1.2",
    "eslint": "^6.8.0",
    "eslint-config-airbnb-base": "14.2.0",
    "eslint-loader": "^3.0.3",
    "eslint-plugin-import": "^2.21.2",
    "gulp": "^4.0.2",
    "gulp-banner": "^0.1.3",
    "gulp-cached": "^1.1.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-filter": "^6.0.0",
    "gulp-hash-filename": "^3.0.0",
    "gulp-if": "^3.0.0",
    "gulp-imagemin": "^7.1.0",
    "gulp-load-plugins": "^2.0.3",
    "gulp-postcss": "^8.0.0",
    "gulp-replace": "^1.0.0",
    "gulp-sass": "^4.1.0",
    "gulp-sass-glob": "^1.1.0",
    "gulp-sourcemaps": "^2.6.5",
    "gulp-svgmin": "^2.2.0",
    "husky": "^4.2.5",
    "imagemin-jpeg-recompress": "^7.0.0",
    "npm-run-all": "^4.1.5",
    "path": "^0.12.7",
    "rimraf": "^3.0.2",
    "webpack": "^4.43.0",
    "webpack-cli": "^3.3.11"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn precommit"
    }
  },
  "browserslist": [
    "last 1 version",
    "> 1%",
    "IE 11"
  ]
}
